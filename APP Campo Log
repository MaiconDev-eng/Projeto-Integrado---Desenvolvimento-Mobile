import 'package:flutter/material.dart';

void main() {
  runApp(const CampoLogApp());
}

class CampoLogApp extends StatelessWidget {
  const CampoLogApp({super.key});

  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      title: 'CampoLog',
      theme: ThemeData(primarySwatch: Colors.green),
      home: const LoginPage(),
    );
  }
}

// 🔐 TELA DE LOGIN (SIMPLES)
class LoginPage extends StatefulWidget {
  const LoginPage({super.key});

  @override
  State<LoginPage> createState() => _LoginPageState();
}

class _LoginPageState extends State<LoginPage> {
  final TextEditingController userController = TextEditingController();

  void login() {
    if (userController.text.isNotEmpty) {
      Navigator.push(
        context,
        MaterialPageRoute(
          builder: (context) => HomePage(usuario: userController.text),
        ),
      );
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      body: Padding(
        padding: const EdgeInsets.all(20),
        child: Column(
          mainAxisAlignment: MainAxisAlignment.center,
          children: [
            const Text('CampoLog', style: TextStyle(fontSize: 28)),
            TextField(
              controller: userController,
              decoration: const InputDecoration(labelText: 'Nome do usuário'),
            ),
            const SizedBox(height: 20),
            ElevatedButton(onPressed: login, child: const Text('Entrar')),
          ],
        ),
      ),
    );
  }
}

// 🏠 HOME COM REGISTROS
class HomePage extends StatefulWidget {
  final String usuario;

  const HomePage({super.key, required this.usuario});

  @override
  State<HomePage> createState() => _HomePageState();
}

class _HomePageState extends State<HomePage> {
  final List<Map<String, String>> registros = [];

  final TextEditingController operadorController = TextEditingController();
  final TextEditingController talhaoController = TextEditingController();
  final TextEditingController atividadeController = TextEditingController();

  void adicionarRegistro() {
    if (operadorController.text.isEmpty ||
        talhaoController.text.isEmpty ||
        atividadeController.text.isEmpty) {
      return;
    }

    setState(() {
      registros.add({
        'operador': operadorController.text,
        'talhao': talhaoController.text,
        'atividade': atividadeController.text,
        'data': DateTime.now().toString().substring(0, 16),
      });
    });

    operadorController.clear();
    talhaoController.clear();
    atividadeController.clear();
  }

  void removerRegistro(int index) {
    setState(() {
      registros.removeAt(index);
    });
  }

  void mostrarFormulario() {
    showDialog(
      context: context,
      builder: (_) => AlertDialog(
        title: const Text('Novo Registro'),
        content: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            TextField(
              controller: operadorController,
              decoration: const InputDecoration(labelText: 'Operador'),
            ),
            TextField(
              controller: talhaoController,
              decoration: const InputDecoration(labelText: 'Talhão'),
            ),
            TextField(
              controller: atividadeController,
              decoration: const InputDecoration(labelText: 'Atividade'),
            ),
          ],
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('Cancelar'),
          ),
          ElevatedButton(
            onPressed: () {
              adicionarRegistro();
              Navigator.pop(context);
            },
            child: const Text('Salvar'),
          )
        ],
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: Text('Bem-vindo, ${widget.usuario}'),
      ),
      floatingActionButton: FloatingActionButton(
        onPressed: mostrarFormulario,
        child: const Icon(Icons.add),
      ),
      body: registros.isEmpty
          ? const Center(child: Text('Nenhum registro ainda'))
          : ListView.builder(
              itemCount: registros.length,
              itemBuilder: (context, index) {
                final item = registros[index];
                return Card(
                  child: ListTile(
                    title: Text(item['atividade'] ?? ''),
                    subtitle: Text(
                        'Operador: ${item['operador']}\nTalhão: ${item['talhao']}\nData: ${item['data']}'),
                    trailing: IconButton(
                      icon: const Icon(Icons.delete),
                      onPressed: () => removerRegistro(index),
                    ),
                  ),
                );
              },
            ),
    );
  }
}
